# Supabase 환경 변수
# Supabase 대시보드 → Project Settings → API 에서 값을 확인하세요.
#   - Project URL                          → NEXT_PUBLIC_SUPABASE_URL
#   - Project API Keys (anon / publishable) → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#
# 이 파일을 복사해 .env.local 로 만든 뒤 실제 값으로 교체하세요.
#   cp .env.example .env.local

NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-or-publishable-key

# 서버 전용 시크릿 (클라이언트 노출 금지 — NEXT_PUBLIC_ 접두사 금지)
# Claude Vision OCR(신고필증 추출)·AI 의미 매칭에 사용. platform.claude.com 에서 발급.
ANTHROPIC_API_KEY=your-anthropic-api-key
